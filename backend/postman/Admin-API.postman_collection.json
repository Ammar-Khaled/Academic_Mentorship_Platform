{
  "info": {
    "_postman_id": "admin-api-collection",
    "name": "Academic Mentorship Admin API",
    "description": "Complete API collection for Admin module including user management and AI audit features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin - User Management",
      "item": [
        {
          "name": "Get Pending Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/pending",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", "pending"]
            },
            "description": "Get all users pending approval"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users?status=pending",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"],
              "query": [
                {
                  "key": "status",
                  "value": "pending",
                  "description": "Filter by status: pending, approved, blocked, rejected"
                }
              ]
            },
            "description": "Get users filtered by approval status"
          }
        },
        {
          "name": "Get User Approval Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/:userId",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", ":userId"],
              "variable": [
                {
                  "key": "userId",
                  "value": "user-id-here"
                }
              ]
            },
            "description": "Get approval status for a specific user"
          }
        },
        {
          "name": "Approve User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approvalNotes\": \"User profile looks good, approved for mentoring\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users/:userId/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", ":userId", "approve"],
              "variable": [
                {
                  "key": "userId",
                  "value": "user-id-here"
                }
              ]
            },
            "description": "Approve a user for access to the platform"
          }
        },
        {
          "name": "Block User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"blockReason\": \"Inappropriate behavior detected in sessions\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users/:userId/block",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", ":userId", "block"],
              "variable": [
                {
                  "key": "userId",
                  "value": "user-id-here"
                }
              ]
            },
            "description": "Block a user from accessing the platform"
          }
        },
        {
          "name": "Unblock User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/:userId/unblock",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", ":userId", "unblock"],
              "variable": [
                {
                  "key": "userId",
                  "value": "user-id-here"
                }
              ]
            },
            "description": "Unblock a previously blocked user"
          }
        },
        {
          "name": "Get Admin Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/statistics",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "statistics"]
            },
            "description": "Get admin dashboard statistics (total users, pending approvals, etc.)"
          }
        }
      ]
    },
    {
      "name": "Admin - AI Audit",
      "item": [
        {
          "name": "Analyze Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/audit/analyze/:sessionId",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "audit", "analyze", ":sessionId"],
              "variable": [
                {
                  "key": "sessionId",
                  "value": "session-id-here"
                }
              ]
            },
            "description": "Analyze a single session with AI predictions"
          }
        },
        {
          "name": "Analyze Multiple Sessions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"session-id-1\", \"session-id-2\", \"session-id-3\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/audit/analyze-batch",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "audit", "analyze-batch"]
            },
            "description": "Batch analyze multiple sessions in one request"
          }
        },
        {
          "name": "Get Recent Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/audit/logs/recent?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "audit", "logs", "recent"],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Number of logs to retrieve (default: 50)"
                }
              ]
            },
            "description": "Get recent audit logs from all sessions"
          }
        },
        {
          "name": "Get Audit Logs by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/audit/logs/by-status/SUCCESS?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "audit", "logs", "by-status", "SUCCESS"],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Number of logs to retrieve"
                }
              ],
              "variable": [
                {
                  "key": "status",
                  "value": "SUCCESS",
                  "description": "Audit status: SUCCESS, FAILED, or PENDING"
                }
              ]
            },
            "description": "Get audit logs filtered by status (SUCCESS, FAILED, PENDING)"
          }
        },
        {
          "name": "Get Session Audit Log",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/audit/logs/:sessionId",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "audit", "logs", ":sessionId"],
              "variable": [
                {
                  "key": "sessionId",
                  "value": "session-id-here"
                }
              ]
            },
            "description": "Get audit log for a specific session"
          }
        },
        {
          "name": "Get Audit Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/audit/statistics",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "audit", "statistics"]
            },
            "description": "Get comprehensive audit statistics and analytics"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "your-jwt-token-here",
      "type": "string"
    }
  ]
}
